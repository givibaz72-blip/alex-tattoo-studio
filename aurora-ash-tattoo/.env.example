# Aurora & Ash Tattoo — environment variables
# Copy this file to .env.local for local development or configure these
# variables in your hosting provider for production.

# Required in production. Use a long random string.
PAYLOAD_SECRET=change-me-use-a-long-random-secret

# Payload database connection.
# Local SQLite example:
DATABASE_URI=file:./payload.db
# Production examples:
# DATABASE_URI=postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# DATABASE_URI=libsql://YOUR_DATABASE.turso.io?authToken=YOUR_TOKEN

# Public site URL used by metadata, live preview, canonical URLs, and admin links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Telegram notifications for new inquiries.
# Create a bot via @BotFather and set the destination chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional conventional runtime flag.
NODE_ENV=development
